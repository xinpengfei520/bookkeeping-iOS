platform :ios, '16.0'
use_frameworks!
inhibit_all_warnings!

target 'bookkeeping' do
    pod 'pop', '1.0.12'
    pod 'SDWebImage', '4.4.3'
    pod 'Masonry', '1.1.0'
    pod 'MJExtension', '3.0.15'
    pod 'JGProgressHUD', '2.0.3'
    pod 'BRPickerView', '2.9.1'
    pod 'Bugly'
end

target 'BookMonth' do
  pod 'MJExtension', '3.0.15'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      # 添加以下设置来解决 pop 库的问题
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      # 确保支持的架构正确
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      # 避免第三方库的 chained-comparison 等历史警告被升级为 error
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
    end

    # Xcode 15+ 要求资源 bundle 也签名，但 CocoaPods 为各 Pod 自动生成的
    # *.Privacy / 资源 bundle 没有 DEVELOPMENT_TEAM。这里统一关掉它们的签名要求。
    if target.respond_to?(:product_type) && target.product_type == 'com.apple.product-type.bundle'
      target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['CODE_SIGN_IDENTITY'] = ''
      end
    end
  end

end
